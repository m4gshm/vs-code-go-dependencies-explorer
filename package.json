{
  "name": "vs-code-go-dependencies-explorer",
  "icon": "icon.png",
  "type": "commonjs",
  "publisher": "m4gshm",
  "displayName": "Go dependencies explorer",
  "description": "File explorer for quickly accessing Go package resources such as .go files and so on.",
  "version": "0.0.5",
  "engines": {
    "vscode": "^1.112.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "workspaceContains:**/*.go",
    "workspaceContains:go.mod",
    "workspaceContains:go.sum",
    "onLanguage:go",
    "onLanguage:go.sum",
    "onLanguage:gotmpl",
    "onLanguage:go.asm",
    "onDebugResolve:go",
    "onWebviewPanel:welcomeGo"
  ],
  "extensionDependencies": [
    "golang.go",
    "vscode.git"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Go Dependencies Explorer",
      "properties": {
        "go.dependencies.explorer.prevent.open.git.repo": {
          "type": "string",
          "enum": [
            "ask",
            "on",
            "off"
          ],
          "default": "ask",
          "description": "Prevent opening git repositories by opening files from \"Standard Library\" or \"External Packages\"."
        }
      }
    },
    "views": {
      "explorer": [
        {
          "id": "go.dependencies.explorer",
          "name": "GO Dependencies",
          "when": "go.dependencies.explorer.show",
          "icon": "Go"
        }
      ]
    },
    "commands": [
      {
        "command": "go.dependencies.refresh",
        "title": "Refresh",
        "description": "Refresh the Go Dependencies.",
        "category": "Explorer",
        "icon": "$(refresh)"
      },
      {
        "command": "go.dependencies.search.in.all.directories",
        "title": "Search in dependencies",
        "description": "Search in dependencies.",
        "category": "Explorer",
        "icon": "$(search)"
      },
      {
        "command": "go.dependencies.copy.path",
        "title": "Copy Path"
      },
      {
        "command": "go.dependencies.open.in.integrated.terminal",
        "title": "Open in Integrated Terminal"
      },
      {
        "command": "go.dependencies.reveal.in.os.mac",
        "title": "Reveal in Finder"
      },
      {
        "command": "go.dependencies.reveal.in.os.windows",
        "title": "Reveal in File Explorer"
      },
      {
        "command": "go.dependencies.reveal.in.os.linux",
        "title": "Reveal in Explorer View"
      },
      {
        "command": "go.dependencies.search.in.directory",
        "title": "Search in directory"
      },
      {
        "command": "go.dependencies.open.in.workspace",
        "title": "Open in Workspace"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "go.dependencies.refresh",
          "when": "view == go.dependencies.explorer",
          "group": "navigation"
        },
        {
          "command": "go.dependencies.search.in.all.directories",
          "when": "view == go.dependencies.explorer",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "when": "view == 'go.dependencies.explorer'",
          "command": "go.dependencies.copy.path"
        },
        {
          "when": "view == 'go.dependencies.explorer' && viewItem == goDir",
          "command": "go.dependencies.search.in.directory"
        },
        {
          "when": "view == 'go.dependencies.explorer' && viewItem == goDir",
          "command": "go.dependencies.open.in.workspace"
        },
        {
          "when": "view == 'go.dependencies.explorer' && viewItem == goDir",
          "command": "go.dependencies.open.in.integrated.terminal"
        },
        {
          "when": "view == 'go.dependencies.explorer' && isWindows",
          "command": "go.dependencies.reveal.in.os.windows"
        },
        {
          "when": "view == 'go.dependencies.explorer' && isMac",
          "command": "go.dependencies.reveal.in.os.mac"
        },
        {
          "when": "view == 'go.dependencies.explorer' && isLinux",
          "command": "go.dependencies.reveal.in.os.linux"
        }
      ]
    }
  },
  "scripts": {
    "rimraf": "./node_modules/rimraf/bin.js",
    "clean": "rimraf ./dist ./out",
    "check-types": "tsc --noEmit",
    "prepackage": "npm run build",
    "package": "npx vsce ls && npx vsce package",
    "vscode:prepublish": "npm run clean && npm run build",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "predist": "npm run compile",
    "dist": "node esbuild.js",
    "dist-watch": "node esbuild.js --watch",
    "lint": "eslint src",
    "test": "node --import tsx --test src/test/**/*.test.ts",
    "prevscode-test": "npm run dist",
    "vscode-test": "vscode-test",
    "build": "npm run clean && npm run vscode-test && npm run test && npm run lint"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.39",
    "@types/semver": "^7.7.1",
    "@types/sinon": "^21.0.1",
    "@types/vscode": "^1.112.0",
    "@types/wu": "^2.1.44",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "esbuild": ">=0.28.0",
    "eslint": "^10.2.0",
    "mocha": "^11.6.0",
    "rimraf": "^6.1.3",
    "sinon": "^21.1.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/m4gshm/vs-code-go-dependencies-explorer.git"
  }
}